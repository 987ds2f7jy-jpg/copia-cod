# ============================================================
# Rápido Doutor — variáveis de ambiente para a suíte E2E
# Copie este arquivo para .env.e2e e preencha os valores.
# .env.e2e está no .gitignore — nunca commite credenciais reais.
# ============================================================

# URL base do app (padrão: Vite dev server)
E2E_BASE_URL=http://localhost:5173

# ── Usuários de teste ────────────────────────────────────────
# Devem existir no banco de desenvolvimento.
# Em CI: criados pelo script de seed antes da suíte rodar.

E2E_PATIENT_EMAIL=paciente-e2e@rapidodoutor.test
E2E_PATIENT_PASSWORD=senha-e2e-paciente

E2E_PROFESSIONAL_EMAIL=profissional-e2e@rapidodoutor.test
E2E_PROFESSIONAL_PASSWORD=senha-e2e-profissional

E2E_ADMIN_EMAIL=admin-e2e@rapidodoutor.test
E2E_ADMIN_PASSWORD=senha-e2e-admin

# ── Usuários de edge cases ───────────────────────────────────

# Conta com is_active=false (para testar ACCOUNT_INACTIVE)
# E2E_INACTIVE_EMAIL=inativo-e2e@rapidodoutor.test
# E2E_INACTIVE_PASSWORD=senha-e2e-inativo

# Profissional com status=pending_review
# E2E_PENDING_PROFESSIONAL_EMAIL=pending-prof-e2e@rapidodoutor.test
# E2E_PENDING_PROFESSIONAL_PASSWORD=senha-e2e-pending

# Profissional com status=suspended
# E2E_SUSPENDED_PROFESSIONAL_EMAIL=suspended-prof-e2e@rapidodoutor.test

# Profissional com status=rejected
# E2E_REJECTED_PROFESSIONAL_EMAIL=rejected-prof-e2e@rapidodoutor.test

# Conta descartável para teste de desativação (usada UMA VEZ)
# E2E_DISPOSABLE_EMAIL=descartavel-e2e@rapidodoutor.test
# E2E_DISPOSABLE_PASSWORD=senha-e2e-descartavel

# Conta já desativada (para testar mensagem de conta inativa pós-desativação)
# E2E_DEACTIVATED_EMAIL=desativado-e2e@rapidodoutor.test
# E2E_DEACTIVATED_PASSWORD=senha-e2e-desativado

# ── IDs de dados de teste ────────────────────────────────────
# public_profile_id de profissional aprovado para testes de agendamento por perfil
# E2E_PROFESSIONAL_PUBLIC_ID=uuid-do-perfil-publico

# IDs de consultas em diferentes status (para testes de teleconsulta)
# E2E_CONSULTA_AGUARDANDO_ID=uuid-da-consulta-aguardando
# E2E_CONSULTA_EM_ATENDIMENTO_ID=uuid-da-consulta-em-atendimento
# E2E_CONSULTA_FINALIZADA_ID=uuid-da-consulta-finalizada
# E2E_CONSULTA_CANCELADA_ID=uuid-da-consulta-cancelada

# ── Flags de dados existentes ────────────────────────────────
# Indicam se os seeds necessários estão disponíveis
# E2E_HAS_ACTIVE_APPOINTMENT=true
# E2E_HAS_COMPLETED_APPOINTMENT=true
# E2E_HAS_CANCELLED_APPOINTMENT=true
# E2E_HAS_REVIEWED_APPOINTMENT=true
# E2E_HAS_ACTIVE_CONSULTATION=true

# ── Flags de permissão para testes destrutivos ───────────────
# Testes que criam ou modificam dados reais ficam desabilitados por padrão
# E2E_ALLOW_REGISTRATION=true      # habilita testes que criam novas contas
# E2E_ALLOW_SCHEDULING=true        # habilita testes que criam agendamentos
# E2E_ALLOW_CANCELLATION=true      # habilita testes que cancelam agendamentos
# E2E_ALLOW_DEACTIVATION=true      # habilita desativação de conta (DESTRUTIVO)
