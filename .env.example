# Frontend Vite (public values bundled in the browser)
VITE_APP_ENV=development
VITE_SUPABASE_URL=(ADICIONAR_URL_SUPABASE_DE_DESENVOLVIMENTO)
VITE_SUPABASE_ANON_KEY=(ADICIONAR_ANON_KEY_PUBLICA)
VITE_SITE_URL=(ADICIONAR_URL_LOCAL)
VITE_MAPBOX_TOKEN=(ADICIONAR_TOKEN_PUBLICO_RESTRITO)
VITE_ENABLE_PAYMENT_SIMULATION=false

# Edge Functions (server-side only; configure with Supabase Secrets)
APP_ENV=development
APP_BASE_URL=(ADICIONAR_URL_LOCAL)
EDGE_ALLOWED_ORIGINS=(ADICIONAR_ORIGEM_LOCAL)
SUPABASE_URL=(FORNECIDA_PELO_SUPABASE)
SUPABASE_ANON_KEY=(FORNECIDA_PELO_SUPABASE)
SUPABASE_SERVICE_ROLE_KEY=(CONFIGURAR_SOMENTE_NO_BACKEND)

# Payments (local may use mock explicitly; never use mock in staging/production)
PAYMENT_PROVIDER=(ADICIONAR_PROVIDER)
ENABLE_PAYMENT_SIMULATION=false
MERCADO_PAGO_ACCESS_TOKEN=(ADICIONAR_SE_USAR_MERCADO_PAGO)
MERCADO_PAGO_WEBHOOK_SECRET=(ADICIONAR_SE_USAR_MERCADO_PAGO)
MERCADO_PAGO_WEBHOOK_URL=(ADICIONAR_SE_USAR_MERCADO_PAGO)
STRIPE_SECRET_KEY=(ADICIONAR_SE_USAR_STRIPE)
STRIPE_WEBHOOK_SECRET=(ADICIONAR_SE_USAR_STRIPE)
STRIPE_PAYMENT_METHOD_MODE=(ADICIONAR_SE_USAR_STRIPE)
STRIPE_ENABLE_PIX=false
STRIPE_PIX_EXPIRES_AFTER_SECONDS=(ADICIONAR_SE_USAR_PIX)
STRIPE_ENABLE_BOLETO=false
STRIPE_BOLETO_EXPIRES_AFTER_DAYS=(ADICIONAR_SE_USAR_BOLETO)

# Plans service (server-to-server)
PLANS_SERVICE_BASE_URL=(ADICIONAR_URL_NAO_PRODUTIVA)
PLANS_SERVICE_INTERNAL_API_KEY=(ADICIONAR_CHAVE_INTERNA)
PLANS_SERVICE_TIMEOUT_MS=(ADICIONAR_TIMEOUT_MS)

# Teleconsultation and assisted documentation (server-side only)
ZOOM_VIDEO_SDK_KEY=(ADICIONAR_IDENTIFICADOR)
ZOOM_VIDEO_SDK_SECRET=(ADICIONAR_SECRET)
ZOOM_WEBHOOK_SECRET_TOKEN=(ADICIONAR_SECRET_WEBHOOK)
DEEPGRAM_API_KEY=(ADICIONAR_CHAVE)
DEEPGRAM_TIMEOUT_MS=(ADICIONAR_TIMEOUT_MS)
GROQ_API_KEY=(ADICIONAR_CHAVE)
GROQ_TIMEOUT_MS=(ADICIONAR_TIMEOUT_MS)
GROQ_MAX_TRANSCRIPT_CHARS=(ADICIONAR_LIMITE_DE_CARACTERES)
