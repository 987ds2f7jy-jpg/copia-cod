# Public browser configuration. Every VITE_* value is bundled in the frontend.
VITE_APP_ENV=development
VITE_BACKEND_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1
VITE_BACKEND_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_MAPBOX_TOKEN=your_mapbox_public_token
VITE_ENABLE_PAYMENT_SIMULATION=false

# Server-only Edge Function configuration. Configure secrets in Supabase,
# never with a VITE_* prefix and never commit real values.
APP_ENV=local
PAYMENT_PROVIDER=mock
ENABLE_PAYMENT_SIMULATION=false
MERCADO_PAGO_ACCESS_TOKEN=replace_with_server_secret
MERCADO_PAGO_WEBHOOK_SECRET=replace_with_server_secret
STRIPE_SECRET_KEY=replace_with_server_secret
STRIPE_WEBHOOK_SECRET=replace_with_server_secret
STRIPE_ENABLE_PIX=false
STRIPE_PIX_EXPIRES_AFTER_SECONDS=1800
