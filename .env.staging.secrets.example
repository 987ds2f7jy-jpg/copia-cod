# Edge Functions/server-side staging configuration. Do not expose these values to Vite.
APP_ENV=staging
APP_BASE_URL=(DEFINIR_DOMINIO_DE_STAGING_HTTPS)
EDGE_ALLOWED_ORIGINS=(DEFINIR_ORIGEM_CANONICA_HTTPS_STAGING)

# Supabase Edge runtime normally provides these remotely.
# Configure manually only for local Edge Function execution if needed:
# SUPABASE_URL=(FORNECIDA_PELO_SUPABASE)
# SUPABASE_ANON_KEY=(FORNECIDA_PELO_SUPABASE)
# SUPABASE_SERVICE_ROLE_KEY=(FORNECIDA_PELO_SUPABASE_RUNTIME)

# Payment sandbox/test credentials only.
PAYMENT_PROVIDER=(ADICIONAR_STRIPE_OU_MERCADOPAGO)
ENABLE_PAYMENT_SIMULATION=false
MERCADO_PAGO_ACCESS_TOKEN=(ADICIONAR_CREDENCIAL_SANDBOX_SE_APLICAVEL)
MERCADO_PAGO_WEBHOOK_SECRET=(ADICIONAR_SECRET_SANDBOX_SE_APLICAVEL)
MERCADO_PAGO_WEBHOOK_URL=(ADICIONAR_URL_WEBHOOK_STAGING_SE_APLICAVEL)
STRIPE_SECRET_KEY=(ADICIONAR_CREDENCIAL_TESTE_SE_APLICAVEL)
STRIPE_WEBHOOK_SECRET=(ADICIONAR_SECRET_TESTE_SE_APLICAVEL)
STRIPE_PAYMENT_METHOD_MODE=(ADICIONAR_DYNAMIC_OU_MANUAL_SE_APLICAVEL)
STRIPE_ENABLE_PIX=false
STRIPE_PIX_EXPIRES_AFTER_SECONDS=(ADICIONAR_SE_APLICAVEL)
STRIPE_ENABLE_BOLETO=false
STRIPE_BOLETO_EXPIRES_AFTER_DAYS=(ADICIONAR_SE_APLICAVEL)

# Server-to-server plans API. PLANS_SERVICE_URL is a deprecated alias.
PLANS_SERVICE_BASE_URL=(ADICIONAR_URL_STAGING_PLANS_SERVICE)
PLANS_SERVICE_INTERNAL_API_KEY=(ADICIONAR_CHAVE_STAGING_SEPARADA)
PLANS_SERVICE_TIMEOUT_MS=(ADICIONAR_TIMEOUT_MS)

# Teleconsultation and assisted documentation. Server-side only.
ZOOM_VIDEO_SDK_KEY=(ADICIONAR_IDENTIFICADOR_STAGING)
ZOOM_VIDEO_SDK_SECRET=(ADICIONAR_SECRET_STAGING)
ZOOM_WEBHOOK_SECRET_TOKEN=(ADICIONAR_SECRET_WEBHOOK_STAGING)
DEEPGRAM_API_KEY=(ADICIONAR_CHAVE_STAGING)
DEEPGRAM_TIMEOUT_MS=(ADICIONAR_TIMEOUT_MS)
GROQ_API_KEY=(ADICIONAR_CHAVE_STAGING)
GROQ_TIMEOUT_MS=(ADICIONAR_TIMEOUT_MS)
GROQ_MAX_TRANSCRIPT_CHARS=(ADICIONAR_LIMITE_DE_CARACTERES)
